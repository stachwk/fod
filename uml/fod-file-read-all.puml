@startuml
title FOD 3.2.20 — sekwencja fod-indexer file read

skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 20
skinparam BoxPadding 10

actor "Użytkownik / msfind" as User
participant "Powłoka / proces wywołujący" as Caller
participant "fod-indexer CLI\ncli.rs + main.rs" as CLI
control "file_read_api::read_file()" as API
database "PostgreSQL\nindex_files\nindex_sources\nindex_file_hashes" as DB
control "Walidacja ścieżki\ni metadanych" as Validation
collections "System plików\nzarejestrowane źródło" as FS
control "hash.rs\nSHA-256 partial/full" as Hash
participant "Warstwa wyjścia" as Output

User -> Caller: fod-indexer [--output json] file read\n--id ID [--offset N] [--length N]
Caller -> CLI: argv
CLI -> CLI: parsowanie ID, offset, length, format

CLI -> API: read_file(repo, file_id, offset, length)

API -> API: file_id > 0?
alt niepoprawny ID
    API --> CLI: file_read_invalid_id
    CLI --> Caller: błąd na stderr, kod != 0
else poprawny ID
    API -> DB: SELECT pliku, źródła,\nmetadanych skanu i hashy\nWHERE id_file = ID
    alt brak rekordu
        DB --> API: 0 wierszy
        API --> CLI: file_read_not_found
        CLI --> Caller: błąd na stderr, kod != 0
    else rekord istnieje
        DB --> API: FileReadRecord
        API -> Validation: validate_index_record()
        Validation -> Validation: regular + scan_status=ok?\nsource_changed=false?\nhash_status != changed_retry_needed?
        alt rekord niedostępny lub oznaczony jako zmieniony
            Validation --> API: file_read_unavailable\nlub file_read_source_changed
            API --> CLI: błąd
            CLI --> Caller: stderr, bez bajtów
        else rekord dopuszczony
            API -> Validation: validate_relative_path(path)
            Validation -> FS: canonicalize(source_root)\ncanonicalize(source_path)
            FS --> Validation: ścieżka kanoniczna
            Validation -> Validation: resolved_path zaczyna się od canonical_root?
            alt ścieżka niebezpieczna / poza źródłem
                Validation --> API: file_read_invalid_source_path
                API --> CLI: błąd
                CLI --> Caller: stderr, bez bajtów
            else ścieżka bezpieczna
                API -> FS: File::open(read-only)
                FS --> API: uchwyt pliku
                API -> FS: metadata() przed odczytem
                FS --> API: size, mtime_ns, inode, device
                API -> Validation: validate_snapshot(indexed, observed)
                alt metadane różnią się
                    Validation --> API: file_read_source_changed
                    API --> CLI: błąd
                    CLI --> Caller: stderr, bez bajtów
                else metadane zgodne
                    opt zapisany partial_hash
                        API -> Hash: compute_partial_hash_from_file()
                        Hash --> API: observed_partial_hash
                    end
                    API -> Hash: compute_full_hash_from_file()
                    Hash --> API: observed_full_sha256

                    alt zapisany full_hash
                        API -> Validation: porównaj full hash
                    else tylko partial_hash
                        API -> Validation: porównaj partial hash
                    else brak zapisanego hasha
                        API -> Validation: basis = metadata-only
                    end

                    alt hash niezgodny / algorytm nieobsługiwany
                        Validation --> API: file_read_source_changed\nlub file_read_unsupported_hash
                        API --> CLI: błąd
                        CLI --> Caller: stderr, bez bajtów
                    else walidacja hasha poprawna
                        API -> FS: seek(offset) + read(range)
                        FS --> API: bytes
                        API -> FS: metadata() po odczycie
                        FS --> API: snapshot_after
                        API -> FS: metadata(canonical_path)
                        FS --> API: path_snapshot_after
                        API -> Validation: porównaj before/after\noraz inode/device ścieżki
                        alt plik zmieniony lub podmieniony w trakcie
                            Validation --> API: file_read_source_changed
                            API --> CLI: błąd
                            CLI --> Caller: stderr, bez bajtów
                        else stabilny plik
                            API -> Output: FileReadOutput\nprovenance + validation + range + bytes
                            alt --output json
                                Output -> Output: Base64(bytes)
                                Output --> CLI: JSON
                                CLI --> Caller: stdout = JSON
                            else tryb tekstowy
                                Output --> CLI: provenance_human_readable()
                                CLI --> Caller: stderr = pochodzenie
                                CLI --> Caller: stdout = surowe bajty
                            end
                        end
                    end
                end
            end
        end
    end
end

note over API,FS
Operacja jest tylko do odczytu:
- brak UPDATE/INSERT/DELETE w PostgreSQL,
- brak zapisu do pliku źródłowego,
- bajty są emitowane dopiero po pełnej rewalidacji.
end note
@enduml


@startuml
title FOD 3.2.20 — aktywność walidacji i odczytu pliku

skinparam shadowing false
skinparam activity {
  BackgroundColor white
  BorderColor black
  DiamondBackgroundColor white
  DiamondBorderColor black
}

start

:Odbierz file_id,\noffset i opcjonalne length;

if (file_id > 0?) then (tak)
else (nie)
  :file_read_invalid_id;
  stop
endif

:SELECT z index_files,\nindex_sources i index_file_hashes;

if (Rekord istnieje?) then (tak)
else (nie)
  :file_read_not_found;
  stop
endif

if (file_kind = regular\ni scan_status = ok?) then (tak)
else (nie)
  :file_read_unavailable;
  stop
endif

if (source_changed = true\nlub hash_status = changed_retry_needed?) then (tak)
  :file_read_source_changed;
  stop
else (nie)
endif

:Sprawdź, czy path jest\nbezpieczną ścieżką względną;

if (Ścieżka względna poprawna?) then (tak)
else (nie)
  :file_read_invalid_source_path;
  stop
endif

:canonicalize(source_root);\ncanonicalize(source_root/path);

if (Plik istnieje i jest dostępny?) then (tak)
else (nie)
  if (NotFound?) then (tak)
    :file_read_source_missing;
  else (PermissionDenied)
    :file_read_access_denied;
  endif
  stop
endif

if (resolved_path jest wewnątrz source_root?) then (tak)
else (nie)
  :file_read_invalid_source_path;
  stop
endif

:Otwórz plik tylko do odczytu;
:Pobierz snapshot_before:\nsize, mtime_ns, inode, device;

if (Zwykły plik?) then (tak)
else (nie)
  :file_read_source_changed;
  stop
endif

:Porównaj snapshot_before\nz metadanymi skanu i hashowania;

if (Metadane zgodne?) then (tak)
else (nie)
  :file_read_source_changed;
  stop
endif

if (Algorytm hasha obsługiwany?) then (tak)
else (nie)
  :file_read_unsupported_hash;
  stop
endif

if (Zapisano partial_hash?) then (tak)
  :Oblicz bieżący partial SHA-256;
else (nie)
endif

:Oblicz bieżący pełny SHA-256;

if (Zapisano full_hash?) then (tak)
  if (Full hash zgodny?) then (tak)
    :validation basis =\nmetadata+full-hash;
  else (nie)
    :file_read_source_changed;
    stop
  endif
else (nie)
  if (Zapisano partial_hash?) then (tak)
    if (Partial hash zgodny?) then (tak)
      :validation basis =\nmetadata+partial-hash;
    else (nie)
      :file_read_source_changed;
      stop
    endif
  else (nie)
    :validation basis = metadata-only;
  endif
endif

if (offset <= file_size?) then (tak)
else (nie)
  :file_read_invalid_range;
  stop
endif

:returned_length = min(length,\nfile_size - offset)\nlub do EOF;
:seek(offset) i odczytaj dokładnie zakres;

if (Odczytano oczekiwaną liczbę bajtów?) then (tak)
else (nie)
  :file_read_source_changed;
  stop
endif

:Pobierz snapshot_after\nz otwartego uchwytu;
:Pobierz bieżące inode/device\nprzez ścieżkę;

if (before = after\ni plik nie został podmieniony?) then (tak)
else (nie)
  :file_read_source_changed;
  stop
endif

:Zbuduj provenance,\nvalidation i range;

if (--output json?) then (tak)
  :Zakoduj bajty Base64;
  :stdout = JSON;
else (nie)
  :stderr = pochodzenie;
  :stdout = surowe bajty;
endif

stop
@enduml


@startuml
title FOD 3.2.20 — komponenty i przepływ danych file read

skinparam shadowing false
skinparam componentStyle rectangle

actor "Użytkownik / msfind" as User

package "fod-indexer" {
  component "CLI\ncli.rs" as CLI
  component "Dyspozytor\nmain.rs" as Main
  component "File Read API\nfile_read_api.rs" as ReadAPI
  component "Hashing\nhash.rs" as Hash
  component "JSON serializer\nserde + Base64" as Json
  component "Raw output\nstdout / stderr" as Raw
}

database "PostgreSQL" as PG {
  component "index_files" as IndexFiles
  component "index_sources" as IndexSources
  component "index_file_hashes" as IndexHashes
}

folder "Zarejestrowane źródło plików" as Source {
  file "source_root/path" as File
}

User --> CLI : file read --id\n[offset, length]
CLI --> Main : FileCommands::Read
Main --> ReadAPI : read_file()

ReadAPI --> IndexFiles : SELECT stabilnego file_id
ReadAPI --> IndexSources : SELECT nazwy, rodzaju,\nroot_path
ReadAPI --> IndexHashes : SELECT partial/full hash\ni observed metadata

ReadAPI --> File : canonicalize, open RO,\nmetadata, seek, read
ReadAPI --> Hash : partial SHA-256\nfull SHA-256
Hash --> File : odczyt z tego samego uchwytu

ReadAPI --> Json : provenance + validation\n+ range + bytes
ReadAPI --> Raw : provenance + bytes

Json --> User : stdout: JSON\nbytes jako Base64
Raw --> User : stderr: provenance\nstdout: surowe bajty

note right of PG
Tylko SELECT.
Brak modyfikacji:
- index_files
- index_sources
- index_file_hashes
end note

note right of Source
Tylko odczyt.
Brak zapisu, zmiany nazw,
usuwania lub markerów.
end note

note bottom of ReadAPI
Granica bezpieczeństwa:
1. walidacja rekordu indeksu,
2. bezpieczna ścieżka,
3. snapshot przed,
4. hash,
5. odczyt zakresu,
6. snapshot po,
7. dopiero wtedy emisja danych.
end note
@enduml


@startuml
title FOD 3.2.20 — maszyna stanów i klasy błędów file read

skinparam shadowing false
hide empty description

state "Żądanie" as Request
state "Walidacja ID" as ValidateId
state "Odczyt rekordu z DB" as Lookup
state "Walidacja rekordu indeksu" as ValidateRecord
state "Walidacja ścieżki" as ValidatePath
state "Otwarcie pliku" as OpenFile
state "Walidacja metadanych" as ValidateMetadata
state "Walidacja hasha" as ValidateHash
state "Odczyt zakresu" as ReadRange
state "Walidacja po odczycie" as ValidateAfter
state "Budowa odpowiedzi" as BuildOutput
state "Sukces: JSON Base64" as JsonSuccess
state "Sukces: raw stdout" as RawSuccess

state "file_read_invalid_id" as EInvalidId <<error>>
state "file_read_not_found" as ENotFound <<error>>
state "file_read_unavailable" as EUnavailable <<error>>
state "file_read_invalid_source_path" as EInvalidPath <<error>>
state "file_read_source_missing" as EMissing <<error>>
state "file_read_access_denied" as EAccess <<error>>
state "file_read_source_changed" as EChanged <<error>>
state "file_read_unsupported_hash" as EHash <<error>>
state "file_read_invalid_range" as ERange <<error>>
state "file_read_io_error" as EIO <<error>>

[*] --> Request
Request --> ValidateId
ValidateId --> EInvalidId : id = 0
ValidateId --> Lookup : id > 0

Lookup --> ENotFound : brak wiersza
Lookup --> ValidateRecord : rekord znaleziony

ValidateRecord --> EUnavailable : nie regular / scan_status != ok
ValidateRecord --> EChanged : source_changed\nlub changed_retry_needed
ValidateRecord --> ValidatePath : rekord dopuszczony

ValidatePath --> EInvalidPath : pusta, absolutna,\nParentDir lub poza root
ValidatePath --> OpenFile : ścieżka bezpieczna

OpenFile --> EMissing : NotFound
OpenFile --> EAccess : PermissionDenied
OpenFile --> EIO : inny błąd I/O
OpenFile --> ValidateMetadata : otwarto read-only

ValidateMetadata --> EChanged : size/mtime/inode/device\nniezgodne
ValidateMetadata --> ValidateHash : metadane zgodne

ValidateHash --> EHash : algorytm != sha256
ValidateHash --> EChanged : partial/full hash niezgodny
ValidateHash --> ReadRange : hash zgodny\nlub metadata-only

ReadRange --> ERange : offset > size\nlub zakres niemożliwy
ReadRange --> EIO : seek/read error
ReadRange --> EChanged : przedwczesny EOF
ReadRange --> ValidateAfter : bajty w buforze

ValidateAfter --> EChanged : snapshot się zmienił\nlub inode/device podmienione
ValidateAfter --> BuildOutput : plik stabilny

BuildOutput --> JsonSuccess : --output json
BuildOutput --> RawSuccess : tryb tekstowy

JsonSuccess --> [*]
RawSuccess --> [*]

EInvalidId --> [*]
ENotFound --> [*]
EUnavailable --> [*]
EInvalidPath --> [*]
EMissing --> [*]
EAccess --> [*]
EChanged --> [*]
EHash --> [*]
ERange --> [*]
EIO --> [*]

note bottom of EChanged
Najważniejsza właściwość:
w każdej ścieżce błędnej
nie są emitowane bajty pliku.
end note
@enduml
